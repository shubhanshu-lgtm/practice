				{
					"name": "Get New User Details",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"var jsonData = pm.response.json();",
									"pm.test(\"User email matches\", function () {",
									"    pm.expect(jsonData.email).to.eql(\"john.doe@intercert.com\");",
									"});",
									"pm.test(\"User has correct department\", function () {",
									"    var deptIds = jsonData.departments.map(d => d.id);",
									"    pm.expect(deptIds).to.include(pm.environment.get(\"deptId\"));",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"auth": {
							"type": "bearer",
							"bearer": [
