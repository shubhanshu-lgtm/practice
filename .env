# Server Configuration
PORT=8080
NODE_ENV=development

# MySQL Database Configuration (Local Development)
DB_NAME=grubpac_db
DB_USER=root
DB_PASSWORD=root
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DIALECT=mysql

# JWT Secret (Change this to a strong random string in production)
JWT_SECRET=grubpac_jwt_secret_key_change_in_production

# File Upload Configuration
UPLOAD_PATH=uploads/
MAX_FILE_SIZE=10485760

# Optional: Database Sync with Alter (set to 'true' only when needed)
# DB_ALTER=false

# Optional: S3 Cloud Storage (leave empty for local storage)
# S3_ACCESS_KEY_ID=
# S3_SECRET_ACCESS_KEY=
# S3_REGION=
# S3_BUCKET_NAME=
# STORAGE_TYPE=local

