{
  "info": {
    "name": "OPMS Leads - Lead & Service APIs",
    "_postman_id": "opms-leads-collection",
    "description": "Collection to test Lead and Service endpoints (create, get, patch). Set `{{baseUrl}}` and `{{jwt}}` in Postman environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "jwt", "value": "" }
  ],
  "item": [
    {
      "name": "Services",
      "item": [
        {
          "name": "Create Service",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/services",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Consulting\",\n  \"code\": \"CONSULT\",\n  \"description\": \"Consulting services\",\n  \"isActive\": true\n}"
            }
          }
        },
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads/services"
          }
        },
        {
          "name": "Update Service (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/services/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Consulting Updated\",\n  \"isActive\": false\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [], "type": "text/javascript" }
            }
          ]
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"Website\",\n  \"notes\": \"Test lead created via Postman\",\n  \"customer\": { \"name\": \"ACME Corporation\" },\n  \"addresses\": [ { \"addressLine1\": \"123 Main St\", \"city\": \"Metropolis\", \"country\": \"Countryland\" } ],\n  \"contacts\": [ { \"name\": \"John Doe\", \"email\": \"john@example.com\", \"phoneNo\": \"1234567890\", \"countryCode\": \"+1\" } ]\n}"
            }
          }
        },
        {
          "name": "Get Leads",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads"
          }
        },
        {
          "name": "Get Lead By Id",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads/:id"
          }
        },
        {
          "name": "Update Lead (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Contacted\",\n  \"notes\": \"Updated via Postman via PUT\",\n  \"serviceIds\": [1,2]\n}"
            }
          }
        },

        {
          "name": "Assign Services To Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/:id/services",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceIds\": [1,2]\n}"
            }
          }
        }
      ]
    }
  ]
}
