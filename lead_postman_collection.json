{
  "info": {
    "name": "OPMS Leads - Lead & Service APIs",
    "_postman_id": "opms-leads-collection",
    "description": "Collection to test Lead and Service endpoints (create, get, patch). Set `{{baseUrl}}` and `{{jwt}}` in Postman environment.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:3000" },
    { "key": "jwt", "value": "" }
  ],
  "item": [
    {
      "name": "Services",
      "item": [
        {
          "name": "Add Service Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads/services/category?type=Category",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "services", "category"],
              "query": [
                { "key": "type", "value": "Category" }
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "ISO Certification", "type": "text" },
                { "key": "code", "value": "ISO", "type": "text" },
                { "key": "service_category", "value": "ISO", "type": "text" },
                { "key": "category_logo", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Add Service Sub-Category",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": {
              "raw": "{{baseUrl}}/leads/services/category?type=Sub-Category",
              "host": ["{{baseUrl}}"],
              "path": ["leads", "services", "category"],
              "query": [
                { "key": "type", "value": "Sub-Category" }
              ]
            },
            "body": {
              "mode": "formdata",
              "formdata": [
                { "key": "name", "value": "ISO 14001:2015 - Environmental Management Systems", "type": "text" },
                { "key": "code", "value": "ISO_14001:2015", "type": "text" },
                { "key": "description", "value": "3-4 weeks", "type": "text" },
                { "key": "service_category", "value": "AUDIT", "type": "text" },
                { "key": "category_logo", "type": "file", "src": [] }
              ]
            }
          }
        },
        {
          "name": "Get Services",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads/services"
          }
        },
        {
          "name": "Update Service (PATCH)",
          "request": {
            "method": "PATCH",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/services/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Consulting Updated\",\n  \"isActive\": false\n}"
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": { "exec": [], "type": "text/javascript" }
            }
          ]
        }
      ]
    },
    {
      "name": "Leads",
      "item": [
        {
          "name": "Create Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"source\": \"Website\",\n  \"notes\": \"Test lead created via Postman\",\n  \"customer\": { \"name\": \"ACME Corporation\" },\n  \"addresses\": [ { \"addressLine1\": \"123 Main St\", \"city\": \"Metropolis\", \"country\": \"Countryland\" } ],\n  \"contacts\": [ { \"name\": \"John Doe\", \"email\": \"john@example.com\", \"phoneNo\": \"1234567890\", \"countryCode\": \"+1\" } ]\n}"
            }
          }
        },
        {
          "name": "Get Leads",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads"
          }
        },
        {
          "name": "Get Lead By Id",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads/:id"
          }
        },
        {
          "name": "Update Lead (PUT)",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"status\": \"Contacted\",\n  \"notes\": \"Updated via Postman via PUT\",\n  \"serviceIds\": [1,2]\n}"
            }
          }
        },

        {
          "name": "Assign Services To Lead",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/:id/services",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"serviceIds\": [1,2]\n}"
            }
          }
        },
        {
          "name": "Create Follow-up",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/:id/followups",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"type\": \"Call\",\n  \"description\": \"Initial outreach call\",\n  \"followUpDate\": \"2026-03-01T10:00:00Z\",\n  \"priority\": \"High\"\n}"
            }
          }
        },
        {
          "name": "Get Lead Follow-ups",
          "request": {
            "method": "GET",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads/:id/followups"
          }
        },
        {
          "name": "Update Follow-up",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{jwt}}" }
            ],
            "url": "{{baseUrl}}/leads/followups/:id",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"isCompleted\": true,\n  \"outcome\": \"Spoke with client, interested\"\n}"
            }
          }
        },
        {
          "name": "Delete Follow-up",
          "request": {
            "method": "DELETE",
            "header": [ { "key": "Authorization", "value": "Bearer {{jwt}}" } ],
            "url": "{{baseUrl}}/leads/followups/:id"
          }
        }
      ]
    }
  ]
}
